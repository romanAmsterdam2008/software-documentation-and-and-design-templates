{{> header}}
{{#if message}}
  <div class="page-header">
    <div>
      <h1 class="page-title">Edit message</h1>
      <div class="page-subtitle"><span class="id-pill">{{message.messageId}}</span></div>
    </div>
    <a href="/messages/{{message.messageId}}" class="btn btn-ghost">← Back</a>
  </div>

  <form method="post" action="/messages/{{message.messageId}}/update" class="card" style="max-width:720px;">
    <div class="card-body">
      <div class="form-group">
        <label class="form-label">Type</label>
        <input class="form-control" value="{{message.type}}" disabled />
      </div>

      {{#if (eq message.type "TEXT")}}
        <div class="form-group">
          <label class="form-label">Text</label>
          <textarea name="text" class="form-control" rows="5">{{message.text}}</textarea>
        </div>
      {{else}}
        <div class="form-group">
          <label class="form-label">File URL</label>
          <input name="fileUrl" class="form-control" value="{{message.fileUrl}}" />
        </div>
        <div class="form-group">
          <label class="form-label">File type</label>
          <input name="fileType" class="form-control" value="{{message.fileType}}" />
        </div>
      {{/if}}
    </div>
    <div class="card-footer">
      <a href="/messages/{{message.messageId}}" class="btn btn-ghost">Cancel</a>
      <button class="btn btn-primary" type="submit">Save changes</button>
    </div>
  </form>
{{else}}
  <div class="alert">Message not found.</div>
{{/if}}
{{> footer}}
